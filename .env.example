# Square API — use sandbox values for dev
SQUARE_ACCESS_TOKEN=EAAAlwODx3VQ...
SQUARE_APP_ID=sandbox-sq0idb-...
SQUARE_LOCATION_ID=
SQUARE_WEBHOOK_SECRET=

# Database — Turso in prod, local SQLite for dev
DATABASE_URL=file:./wrench.db
DATABASE_AUTH_TOKEN=

# App — domain-aware values, set per environment (staging vs production)
# PUBLIC_* vars are exposed to the client. Used for SEO meta, footer mailto, etc.
PUBLIC_SITE_URL=http://localhost:5173
PUBLIC_SUPPORT_EMAIL=info@thewrench.club

# Server-only — absolute origin used to build auth links (verify, reset)
ORIGIN=http://localhost:5173

# Resend transactional email — From address. Must be on a domain verified in Resend.
# Production should use a subdomain (e.g. hello@send.wrenchclub.com) so it doesn't
# conflict with Google Workspace MX/DKIM on the apex.
EMAIL_FROM=Wrench Club <hello@thewrench.club>

SESSION_SECRET=change-me-in-production

# Pre-launch sign-up gate. Comma-separated emails (case-insensitive).
# Empty/unset = open registration (use for dev/staging).
# Set on production to lock down to founder/admin emails until launch.
# Example: AUTH_ALLOWLIST=info@wrenchclub.com,willstone@gmail.com
AUTH_ALLOWLIST=

# Feature flag — hide every mention of the Detail Bay (UI, SEO, emails,
# booking flow) while car-wash zoning is still pending. Square catalog +
# team member stay intact so flipping this back on is a redeploy, not a
# re-setup. Set to "true" to hide.
PUBLIC_HIDE_DETAIL_BAY=

# Umami analytics — self-hosted, cookie-less. SRC + WEBSITE_ID must both be
# set for the tracker to load; leave blank in dev/preview to disable.
#
# In production we serve the tracker through a same-origin proxy at /_a/* so
# adblockers can't filter on Umami's domain. The proxy server-fetches from
# UMAMI_UPSTREAM (server-only) and forwards beacons with the original IP.
#
# DOMAINS (optional, CSV) restricts the tracker to specific hostnames so
# events from staging/preview/local never reach the prod data even if env
# vars get accidentally copied across environments.
#
# BUILD_ID (optional) is attached as data-tag so events can be segmented by
# deploy — set on Railway as ${{RAILWAY_GIT_COMMIT_SHA}}.
PUBLIC_UMAMI_SRC=
PUBLIC_UMAMI_WEBSITE_ID=
PUBLIC_UMAMI_HOST_URL=
PUBLIC_UMAMI_DOMAINS=
PUBLIC_BUILD_ID=

# Server-only — upstream Umami origin for the /_a/* proxy. Defaults to
# https://visit.wrenchclub.com if unset. On Railway production this can
# point at the private network for fastest hop:
# UMAMI_UPSTREAM=http://umami.railway.internal:8080
UMAMI_UPSTREAM=
