{
  "name": "wrench-club",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun scripts/vite-cli.ts dev",
    "build": "bun scripts/vite-cli.ts build",
    "build:railway": "vite build",
    "preview": "bun scripts/vite-cli.ts preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "bun scripts/vitest-cli.ts run",
    "test:watch": "bun scripts/vitest-cli.ts watch",
    "test:coverage": "bun scripts/vitest-cli.ts run --coverage",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "postinstall": "bash postinstall.sh",
    "test:e2e": "bunx playwright test",
    "test:e2e:ui": "bunx playwright test --ui",
    "test:e2e:headed": "bunx playwright test --headed"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7",
    "@libsql/client": "^0.14.0",
    "@lucia-auth/adapter-drizzle": "^1.1.0",
    "drizzle-orm": "^0.40.0",
    "lucia": "^3.2.2",
    "lucide-svelte": "^0.469.0",
    "nanoid": "^5.0.9",
    "oslo": "^1.2.1",
    "resend": "6.11.0",
    "square": "^42.0.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@rollup/wasm-node": "4.60.1",
    "@sveltejs/adapter-node": "^5.2.0",
    "@sveltejs/kit": "^2.15.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@vitest/coverage-v8": "4.1.4",
    "drizzle-kit": "^0.30.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "4.1.4"
  }
}
